# Base URL of the backend API (must be prefixed with NEXT_PUBLIC_ to reach the browser)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Public URL of this site (used for metadata / OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact (shown on the site)
NEXT_PUBLIC_CONTACT_EMAIL=lenkogh.music@gmail.com
NEXT_PUBLIC_MANAGEMENT_EMAIL=lenkogh.music@gmail.com
# WhatsApp number, digits only incl. country code (e.g. 233XXXXXXXXX). Leave blank to hide.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Streaming + social (leave blank until you have them)
NEXT_PUBLIC_SPOTIFY_URL=
NEXT_PUBLIC_APPLE_MUSIC_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
